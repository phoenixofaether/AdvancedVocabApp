{
  "name": "advanced-vocab-app",
  "private": true,
  "version": "0.0.1",
  "description": "Advanced vocabulary learning app for students between Oxford advanced and proficiency level",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "build:shared": "pnpm --filter @vocabapp/shared build",
    "build:all": "pnpm --filter @vocabapp/shared build && pnpm --filter web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "vite-plugin-mkcert>vite": "*"
      }
    }
  }
}
